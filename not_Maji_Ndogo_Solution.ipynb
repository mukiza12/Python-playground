 "cells": [
  {
   "cell_type": "markdown",
   "id": "header",
   "metadata": {},
   "source": [
    "# Maji Ndogo Agriculture Analysis - Complete Solution\n",
    "\n",
    "**Data Loading and Analysis for Automated Farming Systems**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "imports",
   "metadata": {},
   "source": [
    "## Step 1: Import Libraries and Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell1",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from sqlalchemy import create_engine, text\n",
    "\n",
    "# Create an engine for the database\n",
    "engine = create_engine('sqlite:///Maji_Ndogo_farm_survey_small.db')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Check available tables\n",
    "with engine.connect() as connection:\n",
    "    result = connection.execute(text(\"SELECT name FROM sqlite_master WHERE type='table';\"))\n",
    "    for row in result:\n",
    "        print(row)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# SQL Query to join all tables\n",
    "sql_query = \"\"\"\n",
    "SELECT \n",
    "    g.Field_ID,\n",
    "    g.Elevation,\n",
    "    g.Latitude,\n",
    "    g.Longitude,\n",
    "    g.Location,\n",
    "    g.Slope,\n",
    "    w.Rainfall,\n",
    "    w.Min_temperature_C,\n",
    "    w.Max_temperature_C,\n",
    "    w.Ave_temps,\n",
    "    s.Soil_fertility,\n",
    "    s.Soil_type,\n",
    "    s.pH,\n",
    "    f.Pollution_level,\n",
    "    f.Plot_size,\n",
    "    f.Crop_type,\n",
    "    f.Annual_yield,\n",
    "    f.Standard_yield\n",
    "FROM geographic_features g\n",
    "JOIN weather_features w ON g.Field_ID = w.Field_ID\n",
    "JOIN soil_and_crop_features s ON g.Field_ID = s.Field_ID\n",
    "JOIN farm_management_features f ON g.Field_ID = f.Field_ID\n",
    "\"\"\"\n",
    "\n",
    "# Load data into DataFrame\n",
    "with engine.connect() as connection:\n",
    "    MD_agric_df = pd.read_sql_query(text(sql_query), connection)\n",
    "\n",
    "print(f\"✅ Data loaded successfully!\")\n",
    "print(f\"Shape: {MD_agric_df.shape}\")\n",
    "MD_agric_df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell4",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Drop duplicate Field_ID column\n",
    "MD_agric_df.drop(columns='Field_ID', inplace=True)\n",
    "print(\"✅ Dropped Field_ID column\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "data_cleanup",
   "metadata": {},
   "source": [
    "## Step 2: Data Cleanup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Check data types\n",
    "print(MD_agric_df.dtypes)\n",
    "print(f\"\\nUnique crop types: {MD_agric_df['Crop_type'].unique()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fix crop type - convert to lowercase and strip whitespace\n",
    "MD_agric_df['Crop_type'] = MD_agric_df['Crop_type'].str.lower().str.strip()\n",
    "\n",
    "# Fix negative elevation values by converting to absolute values\n",
    "MD_agric_df['Elevation'] = MD_agric_df['Elevation'].abs()\n",
    "\n",
    "# Convert Annual_yield to numeric (handle any non-numeric values)\n",
    "MD_agric_df['Annual_yield'] = pd.to_numeric(MD_agric_df['Annual_yield'], errors='coerce')\n",
    "\n",
    "print(\"✅ Data cleanup complete\")\n",
    "print(f\"\\nUnique crops after cleanup: {MD_agric_df['Crop_type'].nunique()}\")\n",
    "print(f\"Elevation min: {MD_agric_df['Elevation'].min()}\")\n",
    "print(f\"Annual_yield dtype: {MD_agric_df['Annual_yield'].dtype}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "challenge1",
   "metadata": {},
   "source": [
    "## Challenge 1: Uncovering Crop Preferences"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell7",
   "metadata": {},
   "outputs": [],
   "source": [
    "### START FUNCTION\n",
    "def explore_crop_distribution(df, crop_filter):\n",
    "    \"\"\"Filter data by crop type and return mean Rainfall and Elevation.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pd.DataFrame\n",
    "        The agricultural dataset\n",
    "    crop_filter : str\n",
    "        The crop type to filter by\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    tuple : (mean_rainfall, mean_elevation)\n",
    "    \"\"\"\n",
    "    # Filter the dataframe by crop type (convert to lowercase for comparison)\n",
    "    filtered_df = df[df['Crop_type'] == crop_filter.lower()]\n",
    "    \n",
    "    # Calculate mean rainfall and elevation\n",
    "    mean_rainfall = filtered_df['Rainfall'].mean()\n",
    "    mean_elevation = filtered_df['Elevation'].mean()\n",
    "    \n",
    "    # Return as a tuple\n",
    "    return (mean_rainfall, mean_elevation)\n",
    "### END FUNCTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the function\n",
    "print(\"Tea:\")\n",
    "print(explore_crop_distribution(MD_agric_df, \"tea\"))\n",
    "print(f\"Expected: (1534.5079956188388, 775.208667535597)\\n\")\n",
    "\n",
    "print(\"Wheat:\")\n",
    "print(explore_crop_distribution(MD_agric_df, \"wheat\"))\n",
    "print(f\"Expected: (1010.2859910581222, 595.8384148002981)\\n\")\n",
    "\n",
    "print(\"\\nOther crops:\")\n",
    "for crop in ['coffee', 'banana', 'maize', 'rice', 'cassava', 'potato']:\n",
    "    rainfall, elevation = explore_crop_distribution(MD_agric_df, crop)\n",
    "    print(f\"{crop.capitalize():12} - Rainfall: {rainfall:8.2f} mm, Elevation: {elevation:8.2f} m\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "challenge2",
   "metadata": {},
   "source": [
    "## Challenge 2: Finding Fertile Grounds"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell9",
   "metadata": {},
   "outputs": [],
   "source": [
    "### START FUNCTION\n",
    "def analyse_soil_fertility(df):\n",
    "    \"\"\"Group by soil type and return mean soil fertility.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pd.DataFrame\n",
    "        The agricultural dataset\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    pd.Series : Mean soil fertility by soil type\n",
    "    \"\"\"\n",
    "    # Group by soil type and calculate mean soil fertility\n",
    "    result = df.groupby('Soil_type')['Soil_fertility'].mean()\n",
    "    \n",
    "    # Return the series\n",
    "    return result\n",
    "### END FUNCTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell10",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the function\n",
    "soil_fertility_results = analyse_soil_fertility(MD_agric_df)\n",
    "print(soil_fertility_results)\n",
    "print(\"\\nExpected:\")\n",
    "print(\"\"\"Loamy       0.585868\n",
    "Peaty       0.604882\n",
    "Rocky       0.582368\n",
    "Sandy       0.595669\n",
    "Silt        0.652654\n",
    "Volcanic    0.648894\"\"\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "challenge3",
   "metadata": {},
   "source": [
    "## Challenge 3: Climate and Geography Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell11",
   "metadata": {},
   "outputs": [],
   "source": [
    "### START FUNCTION\n",
    "def climate_geography_influence(df, column):\n",
    "    \"\"\"Group by a column and aggregate climate/geography metrics.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pd.DataFrame\n",
    "        The agricultural dataset\n",
    "    column : str\n",
    "        The column to group by (e.g., 'Crop_type')\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    pd.DataFrame : Mean values of climate/geography metrics grouped by column\n",
    "    \"\"\"\n",
    "    # Group by the specified column and calculate means of climate/geography columns\n",
    "    result = df.groupby(column)[['Elevation', 'Min_temperature_C', 'Max_temperature_C', 'Rainfall']].mean()\n",
    "    \n",
    "    # Return the dataframe\n",
    "    return result\n",
    "### END FUNCTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell12",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the function\n",
    "climate_results = climate_geography_influence(MD_agric_df, 'Crop_type')\n",
    "print(climate_results)\n",
    "print(\"\\nExpected:\")\n",
    "print(\"\"\"Crop_type \\tElevation\\tMin_temperature_C\\tMax_temperature_C\\tRainfall\n",
    "banana\\t\\t487.97\\t        -5.35\\t\\t31.99\\t\\t1659.91\n",
