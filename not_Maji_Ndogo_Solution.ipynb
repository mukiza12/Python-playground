    "maize\\t\\t680.60\\t        -4.50\\t\\t30.58\\t\\t681.01\n",
    "potato\\t\\t696.31\\t        -4.38\\t\\t30.30\\t\\t660.29\n",
    "rice\\t\\t352.86\\t        -6.61\\t\\t32.73\\t\\t1632.38\n",
    "tea\\t\\t775.21\\t        -2.86\\t\\t29.95\\t\\t1534.51\n",
    "wheat\\t\\t595.84\\t        -4.97\\t\\t30.97\\t\\t1010.29\"\"\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "challenge4",
   "metadata": {},
   "source": [
    "## Challenge 4: Advanced Sorting - Finding Top Performer"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell13",
   "metadata": {},
   "outputs": [],
   "source": [
    "### START FUNCTION\n",
    "def find_ideal_fields(df):\n",
    "    \"\"\"Find the crop type with the most fields having above-average yield.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pd.DataFrame\n",
    "        The agricultural dataset\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    str : The crop type name\n",
    "    \"\"\"\n",
    "    # Calculate the average Standard_yield across all crops\n",
    "    average_yield = df['Standard_yield'].mean()\n",
    "    \n",
    "    # Filter for above-average Standard_yield\n",
    "    above_average_df = df[df['Standard_yield'] > average_yield]\n",
    "    \n",
    "    # Group by crop type and count occurrences, then sort descending\n",
    "    crop_counts = above_average_df.groupby('Crop_type').size().sort_values(ascending=False)\n",
    "    \n",
    "    # Return the crop type with the highest count\n",
    "    return crop_counts.index[0]\n",
    "### END FUNCTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell14",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the function\n",
    "top_crop = find_ideal_fields(MD_agric_df)\n",
    "print(f\"Top performing crop: {top_crop}\")\n",
    "print(f\"Type: {type(top_crop)}\")\n",
    "print(f\"\\nExpected type: <class 'str'>\")\n",
    "\n",
    "# Show crop distribution for above-average yields\n",
    "average_yield = MD_agric_df['Standard_yield'].mean()\n",
    "above_avg = MD_agric_df[MD_agric_df['Standard_yield'] > average_yield]\n",
    "print(f\"\\nAbove-average yield distribution:\")\n",
    "print(above_avg.groupby('Crop_type').size().sort_values(ascending=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "challenge5",
   "metadata": {},
   "source": [
    "## Challenge 5: Advanced Filtering - Optimal Growing Conditions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell15",
   "metadata": {},
   "outputs": [],
   "source": [
    "### START FUNCTION\n",
    "def find_good_conditions(df, crop_type):\n",
    "    \"\"\"Find fields with optimal growing conditions for a specific crop.\n",
    "    \n",
    "    Conditions:\n",
    "    1. Crop type matches\n",
    "    2. Above-average Standard_yield\n",
    "    3. Average temperature between 12-15°C\n",
    "    4. Pollution level < 0.0001\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pd.DataFrame\n",
    "        The agricultural dataset\n",
    "    crop_type : str\n",
    "        The crop to analyze\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    pd.DataFrame : Filtered dataframe with optimal conditions\n",
    "    \"\"\"\n",
    "    # Calculate average Standard_yield\n",
    "    average_yield = df['Standard_yield'].mean()\n",
    "    \n",
    "    # Apply all filtering conditions\n",
    "    filtered_df = df[\n",
    "        (df['Crop_type'] == crop_type.lower()) &\n",
    "        (df['Standard_yield'] > average_yield) &\n",
    "        (df['Ave_temps'] >= 12) & \n",
    "        (df['Ave_temps'] <= 15) &\n",
    "        (df['Pollution_level'] < 0.0001)\n",
    "    ]\n",
    "    \n",
    "    return filtered_df\n",
    "### END FUNCTION"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell16",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the function\n",
    "tea_conditions = find_good_conditions(MD_agric_df, \"tea\")\n",
    "print(f\"Shape of filtered tea fields: {tea_conditions.shape}\")\n",
    "print(f\"Expected: (14, 17)\")\n",
    "\n",
    "if len(tea_conditions) > 0:\n",
    "    print(f\"\\nOptimal tea fields found: {len(tea_conditions)}\")\n",
    "    print(f\"\\nSample optimal conditions:\")\n",
    "    print(tea_conditions[['Crop_type', 'Standard_yield', 'Ave_temps', 'Pollution_level', 'Soil_fertility']].head())\n",
    "else:\n",
    "    print(\"No fields found with those conditions.\")"
   ]
  },
